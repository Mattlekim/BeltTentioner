<Window x:Class="BeltTensionTest.WPF.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="About Belt Tensioner"
        Width="340" Height="220"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="6"/>
    </shell:WindowChrome.WindowChrome>

    <DockPanel>
        <!-- Title bar matching app theme -->
        <Border DockPanel.Dock="Top" Height="34" Background="{StaticResource BgLightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="About Belt Tensioner" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" MouseDown="TitleBar_MouseDown" />
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Button Width="36" Height="24" Margin="2,0" Click="Close_Click" Content="X" ToolTip="Close" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Padding="16" Background="{StaticResource BgBrush}">
            <StackPanel Margin="8" VerticalAlignment="Center">
                <TextBlock Text="Belt Tensioner" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrightBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Version 1.0.46" FontSize="13" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                <TextBlock Text="&#169; 2026 Riddlersoft Games" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                <Button Content="OK" Width="80" Margin="0,18,0,0" HorizontalAlignment="Center" Click="OK_Click"/>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
