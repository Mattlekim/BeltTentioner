<Window x:Class="BeltTensionTest.WPF.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Belt Tensioner"
        Width="340" Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#12121E"
        Foreground="#A0A0BE"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </Window.Resources>
    <StackPanel Margin="24" VerticalAlignment="Center">
        <TextBlock Text="Belt Tensioner" FontSize="22" FontWeight="Bold"
                   Foreground="#D0D0F0" HorizontalAlignment="Center"/>
        <TextBlock Text="Version 1.0.46" FontSize="13" Margin="0,6,0,0"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="&#169; 2026 Riddlersoft Games" FontSize="12" Margin="0,4,0,0"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Riddlersoft Games" FontSize="12" Margin="0,2,0,0"
                   HorizontalAlignment="Center"/>
        <Button Content="OK" Width="80" Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Click="OK_Click"/>
    </StackPanel>
</Window>
