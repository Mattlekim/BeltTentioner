<Window x:Class="BeltTensionTest.WPF.Views.MotorSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BeltTensionTest.WPF.Views"
        xmlns:properties="clr-namespace:BeltTensionTest.WPF.Properties"
        Title="Motor Settings" Height="320" Width="420" Background="Transparent" Foreground="#A0A0BE" WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters inline -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="#12121E" CornerRadius="6" BorderBrush="#FF333344" BorderThickness="1" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0"  Background="{StaticResource BgLightBrush}" MouseDown="TitleBar_MouseDown">
                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" VerticalAlignment="Center" Margin="12,0,40,0" FontWeight="SemiBold" Foreground="#E0E0FF" />
                <Button Width="36" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Click="CloseButton_Click"
                        Background="Transparent" BorderBrush="Transparent" Foreground="#E0E0FF" FontSize="14" Content="X" ToolTip="{x:Static properties:Resources.CloseToolTip}" />
            </Grid>

            <Grid Grid.Row="1" Margin="10">
                <StackPanel>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="cb_MotorSelect" Grid.Column="0"
                          SelectedIndex="{Binding SelectedMotorIndex}"
                          Height="30"
                          VerticalAlignment="Center"
                          SelectionChanged="cb_MotorSelect_SelectionChanged">
                    <ComboBoxItem Content="Left Motor"/>
                    <ComboBoxItem Content="Right Motor"/>
                </ComboBox>
                <CheckBox Grid.Column="1"
                          Content="Dual Motors"
                          IsChecked="{Binding DualMotorsEnabled}"
                          VerticalAlignment="Center"
                          Margin="10,0,0,0"
                          ToolTip="{x:Static properties:Resources.DualMotorsToolTip}"/>
            </Grid>

            <views:SliderRow Label="Start Angle" Min="0" Max="180"
                             Value="{Binding MotorStart, Mode=TwoWay}"
                             FillBrush="#6496FF" Margin="0,3"
                             IsInteger="True"/>
            <views:SliderRow Label="End Angle" Min="0" Max="180"
                             Value="{Binding MotorEnd, Mode=TwoWay}"
                             FillBrush="#6496FF" Margin="0,3"
                             IsInteger="True"/>
            <CheckBox Content="Inverted"
                      IsChecked="{Binding MotorInverted}"
                      Margin="0,6,0,4"
                      ToolTip="{x:Static properties:Resources.InvertMotorToolTip}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Changes not saved!"
                           Foreground="#FF4040"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Visibility="{Binding ShowChangesNotSaved, Converter={StaticResource BoolToVis}}"/>
                
                <Button Grid.Column="2"
                        Content="Apply"
                        Command="{Binding ApplyMotorSettingsCommand}"
                        Style="{DynamicResource BlueButton}"
                        Width="80"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">

                <views:SliderRow x:Name="sr_TestAngle" Label="Test Angle" Min="0" Max="180"
                 Value="0" FillBrush="#6496FF" Margin="0,6" Width="290" IsInteger="True"/>
                <CheckBox x:Name="cb_Test"
                          Content="Test"
                          Checked="Cb_Test_Checked"
                          Unchecked="Cb_Test_Unchecked"
                          Background="Orange"
                          Foreground="Black"
                          Width="80"
                          VerticalAlignment="Center"
                          Margin="15,0,0,0"
                          ToolTip="{x:Static properties:Resources.MotorTestModeToolTip}"/>
            </StackPanel>
            
        </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
