<Window x:Class="BeltTensionTest.WPF.Views.FlashNanoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flash Nano" Height="360" Width="560" Background="#12121E" Foreground="#A0A0BE">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="COM Port:" VerticalAlignment="Center" Margin="0,4,8,0"/>
                <ComboBox x:Name="comboPorts" Width="180" VerticalAlignment="Center"/>
                <Button x:Name="btnRefresh" Content="Refresh" Width="75" Margin="8,0"/>
                <Button x:Name="btnFlash" Content="Flash" Width="75" Margin="8,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="btnLocate" Content="Locate avrdude.exe..." Width="160"/>
                <TextBlock Margin="8,6,0,0" VerticalAlignment="Center">
                    <Hyperlink NavigateUri="https://www.arduino.cc/en/software" RequestNavigate="Hyperlink_RequestNavigate">Install Arduino / avrdude</Hyperlink>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Output:" Margin="0,4,0,4"/>
        <TextBox x:Name="txtOutput" Grid.Row="2" Margin="0,24,0,0" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Background="#10101A" Foreground="#E0E0FF"/>
    </Grid>
</Window>
