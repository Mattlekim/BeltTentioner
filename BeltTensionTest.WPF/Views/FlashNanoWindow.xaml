<Window x:Class="BeltTensionTest.WPF.Views.FlashNanoWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flash Nano" Height="360" Width="560" Background="Transparent" Foreground="#A0A0BE" WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False">

    
    
	<Border Background="#12121E" CornerRadius="6" BorderBrush="#FF333344" BorderThickness="1" Padding="0">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="36" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

      <!-- Title bar -->
		<Grid Grid.Row="0" Background="{StaticResource BgLightBrush}" MouseDown="TitleBar_MouseDown">
			<TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" VerticalAlignment="Center" Margin="12,0,40,0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
			<Button Width="36" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Click="CloseButton_Click"
					Background="Transparent" BorderBrush="Transparent" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
				<Viewbox Width="14" Height="14">
					<Canvas Width="16" Height="16">
						<Path Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2" Data="M4,4 L12,12 M12,4 L4,12" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
					</Canvas>
				</Viewbox>
			</Button>
		</Grid>

			<Grid Grid.Row="1" Margin="10">
				<Grid Margin="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="3*"/>
			<ColumnDefinition/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="8"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8" Grid.RowSpan="2">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="COM Port:" VerticalAlignment="Center" Margin="0,4,8,0"/>
				<ComboBox x:Name="comboPorts" Width="180" VerticalAlignment="Center"/>
               
                <Button x:Name="btnRefresh" Content="Refresh" Width="75" Margin="8,0"/>
				<Button x:Name="btnFlash" Content="Flash" Width="75" Margin="8,0" Background="#FFA2FF64" HorizontalAlignment="Right"/>
			</StackPanel>
            <StackPanel Orientation="Horizontal">
                <Label x:Name="lblPortStatus" Content="No device detected" Margin="8,0" VerticalAlignment="Center" Foreground="#FFB11313"/>
            </StackPanel>
			<StackPanel Orientation="Horizontal" Margin="0,8,0,0">
				<TextBlock Text="Bootloader:" VerticalAlignment="Center" Margin="0,4,8,0"/>
				<ComboBox x:Name="comboBootloader" Width="220" VerticalAlignment="Center">
					<ComboBoxItem Content="Auto" IsSelected="True" />
					<ComboBoxItem Content="New (115200 baud)" />
					<ComboBoxItem Content="Old (57600 baud)" />
				</ComboBox>
				<Button x:Name="btnLocate" Content="Locate avrdude.exe..." Width="160" Margin="8,0,0,0" Background="#FFB11313" HorizontalAlignment="Right"/>
			</StackPanel>
			<StackPanel Orientation="Horizontal" Margin="0,6,0,0">
				<ProgressBar x:Name="progressBusy" Width="80" Height="18" Margin="0,0,8,0" IsIndeterminate="True" Visibility="Collapsed"/>
				<TextBlock x:Name="txtStatusAnim" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#E0E0FF" />
				<TextBlock VerticalAlignment="Center">
                    <Hyperlink NavigateUri="https://www.nongnu.org/avrdude/" RequestNavigate="Hyperlink_RequestNavigate">avrdude project page</Hyperlink>
				</TextBlock>
			</StackPanel>
		</StackPanel>

		<TextBlock Grid.Row="2" Text="Output:" Margin="0,4,0,4" Grid.ColumnSpan="2"/>
		<TextBox x:Name="txtOutput" Grid.Row="2" Margin="0,24,0,0" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" TextWrapping="Wrap" IsReadOnly="True" Background="#10101A" Foreground="#E0E0FF" Grid.ColumnSpan="2"/>
                </Grid>
			</Grid>
		</Grid>
	</Border>
</Window>
