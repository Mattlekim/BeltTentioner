<UserControl x:Class="BeltTensionTest.WPF.Views.SliderRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="50"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Text="{Binding Label, ElementName=Root}"
                   Style="{StaticResource LabelStyle}"
                   VerticalAlignment="Center"/>
        <Slider Grid.Column="1"
                Minimum="{Binding Min, ElementName=Root}"
                Maximum="{Binding Max, ElementName=Root}"
                Value="{Binding Value, ElementName=Root, Mode=TwoWay}"
                Tag="{Binding FillBrush, ElementName=Root}"
                VerticalAlignment="Center"
                Margin="4,0"/>
        <TextBox Grid.Column="2"
                 Text="{Binding Value, ElementName=Root, Mode=TwoWay, StringFormat={}{0:F0}}"
                 VerticalAlignment="Center"
                 TextAlignment="Center"
                 FontSize="11"/>
    </Grid>
</UserControl>
