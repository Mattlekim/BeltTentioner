<Window x:Class="BeltTensionTest.WPF.Views.TestingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Testing" Width="700" Height="620"
        Background="#12121E" Foreground="#A0A0BE"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- ?? Sweep Controls ??????????????????????????????????????????? -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnSurge" Content="Sweep Surge"
                    Command="{Binding StartSurgeCommand}"
                    Width="110" Margin="0,0,6,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SurgeActive}" Value="True">
                                <Setter Property="Background" Value="#3A5AFF"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Sweep Sway"
                    Command="{Binding StartSwayCommand}"
                    Width="110" Margin="0,0,6,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="#30A050"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SwayActive}" Value="True">
                                <Setter Property="Background" Value="#20C060"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Sweep Heave"
                    Command="{Binding StartHeaveCommand}"
                    Width="110" Margin="0,0,6,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Background" Value="#C06010"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HeaveActive}" Value="True">
                                <Setter Property="Background" Value="#FF8020"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="BorderBrush" Value="White"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Stop"
                    Command="{Binding StopCommand}"
                    Background="#DC3C3C"
                    Width="80"/>
			<Button Content="Slow"
				
				Background="#FF401313"
				Width="80" Click="Button_Click"/>
		</StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusText}"
                   Foreground="#D0D0F0"
                   Margin="0,0,0,8"/>

        <!-- ?? Curve Graph ?????????????????????????????????????????????? -->
        <Border Grid.Row="2"
                Background="#12121E"
                BorderBrush="#46466A"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Graph checkboxes -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
                    <CheckBox Content="Braking"   IsChecked="{Binding ShowBraking}"   Foreground="#6496FF" Margin="0,0,12,0"/>
                    <CheckBox Content="Cornering" IsChecked="{Binding ShowCornering}" Foreground="#50C878" Margin="0,0,12,0"/>
                    <CheckBox Content="Vertical"  IsChecked="{Binding ShowVertical}"  Foreground="#FF8040" Margin="0,0,12,0"/>
                    <CheckBox Content="Live Preview" IsChecked="{Binding LivePreview}" Margin="0,0,0,0"/>
                </StackPanel>

                <!-- Canvas for curve graph (drawn in code-behind) -->
                <Image Grid.Row="1" x:Name="CurveGraphImage"
                       Stretch="Fill" Margin="4"/>
            </Grid>
        </Border>

        <!-- ?? Rotation Labels ???????????????????????????????????????? -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="{Binding PitchText}" Foreground="#A0A0BE" Margin="0,0,20,0"/>
            <TextBlock Text="{Binding RollText}"  Foreground="#A0A0BE"/>
        </StackPanel>

        <!-- ?? Motor Output Graph ??????????????????????????????????? -->
        <Border Grid.Row="4"
                Background="#12121E"
                BorderBrush="#46466A"
                BorderThickness="1"
                CornerRadius="4">
            <Image x:Name="MotorGraphImage"
                   Stretch="Fill" Margin="4"/>
        </Border>
    </Grid>
</Window>
