<Window x:Class="BeltTensionTest.WPF.Views.TestingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:properties="clr-namespace:BeltTensionTest.WPF.Properties"
        Title="Testing" Width="700" Height="620"
        Background="#12121E" Foreground="#A0A0BE"
        FontFamily="Segoe UI" WindowStyle="None">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6"/>
    </shell:WindowChrome.WindowChrome>

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="TaskbarInfo" />
    </Window.TaskbarItemInfo>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- Simple vector overlay icon for pinned state (white pin) -->
            <DrawingImage x:Key="PinOverlayImage">
                <DrawingImage.Drawing>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <!-- pin head -->
                                <EllipseGeometry Center="6,4" RadiusX="3" RadiusY="3" />
                                <!-- pin shaft -->
                                <RectangleGeometry Rect="5.5,6,1,6" />
                                <!-- pin tip triangle -->
                                <PathGeometry>
                                    <PathFigure StartPoint="3,12">
                                        <LineSegment Point="9,12" />
                                        <LineSegment Point="6,16" />
                                        <LineSegment Point="3,12" />
                                    </PathFigure>
                                </PathGeometry>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingImage.Drawing>
            </DrawingImage>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>

        <Border DockPanel.Dock="Top" Height="40" Background="{StaticResource BgLightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="Testing And Telemetry" MouseDown="TitleBar_MouseDown"/>
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Pin toggle: when checked window stays on top and taskbar shows overlay -->
                    <ToggleButton x:Name="BtnPin" Width="36" Height="24" Margin="2,0" ToolTip="{x:Static properties:Resources.PinOnTopToolTip}" Background="Transparent"
                                  shell:WindowChrome.IsHitTestVisibleInChrome="True" Checked="Pin_Checked" Unchecked="Pin_Unchecked">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="16" Height="16">
                                <!-- simple pin glyph -->
                                <Path x:Name="PinPath" Fill="{StaticResource TextPrimaryBrush}" Data="M6,2 A4,4 0 1 1 5.99,2 Z M7,6 L7,12 M4,12 L10,12 L7,16 Z"/>
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>
                    <!-- Minimize (horizontal line) -->
                    <Button Width="36" Height="24" Margin="2,0" Click="Minimize_Click" ToolTip="{x:Static properties:Resources.MinimizeToolTip}" Background="Transparent"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="16" Height="16">
                                <Path Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2" Data="M2,8 L14,8" StrokeStartLineCap="Square" StrokeEndLineCap="Square"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Maximize (square) -->
                    <Button Width="36" Height="24" Margin="2,0" Click="MaximizeRestore_Click" ToolTip="{x:Static properties:Resources.MaximizeToolTip}" Background="Transparent"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="16" Height="16">
                                <Path Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2" Data="M3,3 L13,3 L13,13 L3,13 Z" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Close (X) -->
                    <Button Width="36" Height="24" Margin="2,0" Click="Close_Click" ToolTip="{x:Static properties:Resources.CloseToolTip}" Background="Transparent"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="16" Height="16">
                                <Path Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2" Data="M4,4 L12,12 M12,4 L4,12" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- ?? Sweep Controls ??????????????????????????????????????????? -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnSurge" Content="Sweep Surge"
                    Command="{Binding StartSurgeCommand}"
                    Width="110" Margin="0,0,6,0" Style="{DynamicResource BlueButton}"/>
            <Button Content="Sweep Sway"
                    Command="{Binding StartSwayCommand}"
                    Width="110" Margin="0,0,6,0" Style="{DynamicResource GreenButton}"/>
            <Button Content="Sweep Heave"
                    Command="{Binding StartHeaveCommand}"
                    Width="110" Margin="0,0,6,0" Style="{DynamicResource OrangeButton}"/>
            <Button Content="Stop"
                    Command="{Binding StopCommand}"
                    Background="#DC3C3C"
                    Width="80" Style="{DynamicResource RedButton}"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusText}"
                   Foreground="#D0D0F0"
                   Margin="0,0,0,8"/>

        <!-- ABS and Rumble status indicators -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,24,0,8">
            <Border Background="#202034" BorderBrush="#46466A" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ABS: " Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding AbsStatus}" Foreground="#FF8080"/>
                </StackPanel>
            </Border>
            </StackPanel>

        <!-- ?? Curve Graph ?????????????????????????????????????????????? -->
        <Border Grid.Row="2"
                Background="#12121E"
                BorderBrush="#46466A"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Graph checkboxes -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,6">
                    <CheckBox Content="Braking"   IsChecked="{Binding ShowBraking}"   Foreground="#6496FF" Margin="0,0,12,0"
                              ToolTip="{x:Static properties:Resources.ShowBrakingCurveToolTip}"/>
                    <CheckBox Content="Cornering" IsChecked="{Binding ShowCornering}" Foreground="#50C878" Margin="0,0,12,0"
                              ToolTip="{x:Static properties:Resources.ShowCorneringCurveToolTip}"/>
                    <CheckBox Content="Vertical"  IsChecked="{Binding ShowVertical}"  Foreground="#FF8040" Margin="0,0,12,0"
                              ToolTip="{x:Static properties:Resources.ShowVerticalCurveToolTip}"/>
                    <CheckBox Content="Live Preview" IsChecked="{Binding LivePreview}" Margin="0,0,0,0"
                              ToolTip="{x:Static properties:Resources.LivePreviewToolTip}"/>
                </StackPanel>

                <!-- Canvas for curve graph (drawn in code-behind) -->
                <Image Grid.Row="1" x:Name="CurveGraphImage"
                       Stretch="Fill" Margin="4"/>
            </Grid>
        </Border>

        <!-- ?? Rotation Labels ???????????????????????????????????????? -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="{Binding PitchText}" Foreground="#A0A0BE" Margin="0,0,20,0"/>
            <TextBlock Text="{Binding RollText}"  Foreground="#A0A0BE"/>
        </StackPanel>

        <!-- ?? Motor Output Graph ??????????????????????????????????? -->
        <Border Grid.Row="4"
                Background="#12121E"
                BorderBrush="#46466A"
                BorderThickness="1"
                CornerRadius="4">
            <Image x:Name="MotorGraphImage"
                   Stretch="Fill" Margin="4"/>
        </Border>
    </Grid>
    </DockPanel>
</Window>
