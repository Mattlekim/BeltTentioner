<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="BeltTensionTest.WPF.Views.BuyMeCoffeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:properties="clr-namespace:BeltTensionTest.WPF.Properties"
        Title="Buy me a coffee"
        Width="380" Height="220"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
		
        </ResourceDictionary>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="6"/>
    </shell:WindowChrome.WindowChrome>

    <DockPanel>
        <Border DockPanel.Dock="Top" Height="34" Background="{StaticResource BgLightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Static properties:Resources.SupportProjectTitle}" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" MouseDown="TitleBar_MouseDown" />
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Button Width="36" Height="24" Margin="2,0" Click="Close_Click"  Content="X" ToolTip="{x:Static properties:Resources.CloseToolTip}" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Padding="16" Background="{StaticResource BgBrush}">
            <StackPanel Margin="8" VerticalAlignment="Center">
                <TextBlock Text="Buy me a coffee" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrightBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="If you like this project, you can support development by buying a coffee." TextWrapping="Wrap" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <Button x:Name="btn_Buy" Content="{x:Static properties:Resources.WindowTitle}" Width="140" Height="32" Click="Buy_Click" Background="{StaticResource AccentBlueBrush}" Foreground="White" Style="{DynamicResource BlueButton}" ToolTip="{x:Static properties:Resources.BuyButtonToolTip}"/>
                    <Button Style="{DynamicResource BlueButton}" Content="Later" Width="80" Height="32" Margin="8,0,0,0" Click="Close_Click" ToolTip="{x:Static properties:Resources.LaterButtonToolTip}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>