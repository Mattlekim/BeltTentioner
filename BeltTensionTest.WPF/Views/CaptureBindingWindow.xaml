<Window x:Class="BeltTensionTest.WPF.Views.CaptureBindingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:properties="clr-namespace:BeltTensionTest.WPF.Properties"
        Title="Set Binding"
        Width="360" Height="280"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="6"/>
    </shell:WindowChrome.WindowChrome>

    <DockPanel>
        <!-- Title bar matching app theme -->
        <Border DockPanel.Dock="Top" Height="34" Background="{StaticResource BgLightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Set Binding" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" MouseDown="TitleBar_MouseDown" />
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Width="36" Height="24" Margin="2,0" Click="Cancel_Click" Content="X" ToolTip="{x:Static properties:Resources.CloseToolTip}" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}" shell:WindowChrome.IsHitTestVisibleInChrome="True" FontSize="14" FontWeight="SemiBold" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Padding="16" Background="{StaticResource BgBrush}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Press any key or gamepad button…"
                           FontSize="14" HorizontalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="…or pick an F13–F24 key below for Stream Deck."
                           FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"
                           Foreground="{StaticResource BorderBrush}"/>
                <Border Margin="0,12,0,0" Background="{StaticResource BgLightBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="8,6">
                    <TextBlock x:Name="txt_Pending" Text="None" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Foreground="{StaticResource AccentBlueBrush}"/>
                </Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                    <TextBlock Text="Stream Deck key:" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               ToolTip="F13–F24 keys don't exist on a physical keyboard, so they never conflict with the sim. Assign one here, then use a Stream Deck 'Hotkey' action sending the same key."/>
                    <ComboBox x:Name="cmb_StreamDeckKey" Width="90" SelectionChanged="StreamDeckKey_SelectionChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button x:Name="btn_Ok" Content="OK" Width="80" Margin="0,0,8,0" Click="Ok_Click" Style="{DynamicResource GreenButton}"/>
                    <Button x:Name="btn_Cancel" Content="Cancel" Width="80" Click="Cancel_Click" Style="{DynamicResource BlueButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
