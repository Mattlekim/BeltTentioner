<UserControl x:Class="BeltTensionTest.WPF.Views.KeyBindingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="28">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border x:Name="PART_Box" Grid.Column="0" Margin="6,4" MinHeight="32" Cursor="Hand"
                Background="{StaticResource BgLightBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3"
                ToolTip="Click to set this binding">
            <TextBlock x:Name="PART_Text" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="8,0" FontSize="15" FontWeight="SemiBold"/>
        </Border>
        <Button x:Name="PART_Clear" Grid.Column="1" Content="Clear" VerticalAlignment="Center" Margin="4,0,0,0" Padding="8,2"
                Click="PART_Clear_Click" ToolTip="Clear this binding" Style="{DynamicResource BlueButton}"/>
        <CheckBox x:Name="PART_Global" Grid.Column="2" Content="Global" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource TextPrimaryBrush}"/>
    </Grid>
</UserControl>