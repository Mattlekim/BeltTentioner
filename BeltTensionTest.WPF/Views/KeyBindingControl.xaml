<UserControl x:Class="BeltTensionTest.WPF.Views.KeyBindingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="28">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
		<TextBox x:Name="PART_Text"
			 Grid.Column="0"
			 Margin="6,4"
			 IsReadOnly="True"
			 BorderBrush="{StaticResource BorderBrush}"
			 BorderThickness="1"
			 Padding="4,2">

			<!-- Local brush so animation works -->
			<TextBox.Background>
				<SolidColorBrush Color="#F0F0F0"/>
			</TextBox.Background>

			<TextBox.Triggers>
				<EventTrigger RoutedEvent="GotFocus">
					<BeginStoryboard>
						<Storyboard>
							<ColorAnimation Storyboard.TargetProperty="(TextBox.Background).(SolidColorBrush.Color)"
											To="DodgerBlue" Duration="0:0:0.1"/>
						</Storyboard>
					</BeginStoryboard>
				</EventTrigger>

				<EventTrigger RoutedEvent="LostFocus">
					<BeginStoryboard>
						<Storyboard>
							<ColorAnimation Storyboard.TargetProperty="(TextBox.Background).(SolidColorBrush.Color)"
											To="#F0F0F0" Duration="0:0:0.1"/>
						</Storyboard>
					</BeginStoryboard>
				</EventTrigger>
			</TextBox.Triggers>

		</TextBox>

		Grid.Column="0"
		Margin="6,4"
		IsReadOnly="True"
		BorderBrush="{StaticResource BorderBrush}"
		BorderThickness="1"
		Padding="4,2">

		<!-- Local brush so animation works -->
    <TextBox.Background>
        <SolidColorBrush Color="#F0F0F0"/>
    </TextBox.Background>

    <TextBox.Triggers>
        <EventTrigger RoutedEvent="GotFocus">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetProperty="(TextBox.Background).(SolidColorBrush.Color)"
                                    To="DodgerBlue" Duration="0:0:0.1"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>

        <EventTrigger RoutedEvent="LostFocus">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetProperty="(TextBox.Background).(SolidColorBrush.Color)"
                                    To="#F0F0F0" Duration="0:0:0.1"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </TextBox.Triggers>

</TextBox>


		<CheckBox x:Name="PART_Global" Grid.Column="1" Content="Global" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{StaticResource TextPrimaryBrush}"/>
    </Grid>
</UserControl>