<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BeltTensionTest.WPF.ViewModels"
        xmlns:views="clr-namespace:BeltTensionTest.WPF.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:properties="clr-namespace:BeltTensionTest.WPF.Properties"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="BeltTensionTest.WPF.Views.MainWindow"
        Title="BBT"
        Width="420" MinWidth="420"
        MinHeight="400"
        Background="#12121E"
        Foreground="#A0A0BE"
        FontFamily="Segoe UI"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters inline -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <!-- Increase caption height slightly to ensure title bar controls are fully visible and clickable -->
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <DockPanel>

        <Border DockPanel.Dock="Top" Height="40" Background="{StaticResource BgLightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="BBT" MouseDown="TitleBar_MouseDown"/>
                    <views:StatusIndicatorView x:Name="DeviceStatusIndicator" Margin="8,0,0,0"
                                              Label="{Binding DeviceStatusText}"
                                              IsOn="{Binding DeviceIsOn}"
                                              FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Width="36" Height="24" Margin="2,0" Click="Minimize_Click" Content="─" ToolTip="{x:Static properties:Resources.MinimizeToolTip}" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            FontSize="14" FontWeight="SemiBold" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                    
                    <Button Width="36" Height="24" Margin="2,0" Click="Close_Click" Content="X" ToolTip="{x:Static properties:Resources.CloseToolTip}" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            FontSize="14" FontWeight="SemiBold" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- ?? Menu Bar ???????????????????????????????????????????????????? -->
        <DockPanel DockPanel.Dock="Top" Background="#12121E" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                <Button x:Name="bnt_Connect" Content="Connect" Command="{Binding ConnectCommand}" Click="bnt_Connect_Click"
                        Background="Green" Foreground="Black" Width="99" Height="26" Margin="0,0,4,0" VerticalAlignment="Center"/>
                <views:StatusIndicatorView Label="IRacing:" IsOn="{Binding IracingIsOn}" Margin="0,0,8,0"/>
                <views:StatusIndicatorView Label="SimHub:" IsOn="{Binding SimHubIsOn}"/>
            </StackPanel>
        <Menu Background="#12121E"
              Foreground="#A0A0BE" Height="24"
              Margin="0,6,0,0">
                <MenuItem Header="Settings" Click="MenuItem_Click">
                    <MenuItem Header="Preferences..." Click="OpenPreferences_Click"/>
                    <Separator/>
                    <MenuItem Header="Open Testing Window..." Click="OpenTestingWindow_Click"/>
                    <MenuItem Header="Show Debug Log..." Click="OpenDebugLog_Click"/>
                    <MenuItem Header="Flash Nano..." Click="OpenFlashNano_Click"/>
                    <MenuItem Header="Motor Settings..." Click="OpenMotorSettings_Click"/>
                    <Separator/>
                </MenuItem>

                <!-- Help menu moved out from Settings -->
            <MenuItem Header="Help" Foreground="#A0A0BE">
                <MenuItem Header="Check for Updates..."
                          Foreground="#A0A0BE"
                          Command="{Binding CheckUpdatesCommand}"/>
                <MenuItem Header="About..."
                          Foreground="#A0A0BE"
                          Click="About_Click"/>
                <MenuItem Header="Buy me a coffee..."
                          Foreground="#A0A0BE"
                          Click="OpenBuyMeACoffee_Click"/>
            </MenuItem>
        </Menu>
        </DockPanel>

        <!-- Update Banner -->
        <Border DockPanel.Dock="Top"
                Background="#3A2A10"
                BorderBrush="#FFAA20"
                BorderThickness="0,0,0,1"
                Padding="10,5"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{Binding UpdateButtonText}"
                        Background="#FFAA20"
                        Foreground="#12121E"
                        Padding="10,3"
                        Command="{Binding UpdateButtonCommand}"
                        Margin="6,0,0,0" Style="{DynamicResource OrangeButton}"/>
                <TextBlock VerticalAlignment="Center"
                           Foreground="#FFCC60"
                           Text="{Binding UpdateBannerMessage, Mode=OneWay}"
                           FontWeight="Bold" />
            </DockPanel>
        </Border>

        <!-- Main content: keep the connect controls visible, move everything else into tabs -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0">

            <!-- Device Connection (keep visible outside tabs) -->

                <!-- SimHub group -->
            <GroupBox Header="SimHub"
                                      IsEnabled="{Binding SimHubGroupEnabled}"
                                      Visibility="{Binding SimHubIsOn, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding SimHubText}"
                                               Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding MenuStateText}"
                                               Style="{StaticResource LabelStyle}"
                                               HorizontalAlignment="Right"/>
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                                                Orientation="Horizontal" Margin="0,4,0,0">
                        <views:StatusIndicatorView Label="Vertical"   IsOn="{Binding SupportVertical}"  Margin="0,0,8,0"/>
                        <views:StatusIndicatorView Label="Braking"    IsOn="{Binding SupportBrake}"     Margin="0,0,8,0"/>
                        <views:StatusIndicatorView Label="Cornering"  IsOn="{Binding SupportCornering}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Border Margin="10,0,10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Background="{StaticResource BgBrush}">
                <TabControl Style="{StaticResource MyTabControl}" Width="370" BorderThickness="0" Background="{StaticResource BgBrush}"
                            SelectionChanged="TabControl_SelectionChanged">

                    <TabItem Header="Belt Tentioner">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="#12121E"
                                  PanningMode="VerticalFirst" Margin="2,0,1,0">
                            <StackPanel Margin="10,8" Width="332">

                                <!-- Master enable: only when checked are belt motor commands sent to the nano -->
                                <CheckBox Content="Send belt motor commands"
                                          IsChecked="{Binding BeltMotorEnabled, Mode=TwoWay}"
                                          FontWeight="SemiBold"
                                          Foreground="#D0D0F0"
                                          Margin="0,0,0,8"
                                          ToolTip="{x:Static properties:Resources.SendBeltMotorCommandsToolTip}"/>

                                <!-- Car Settings -->
                                <GroupBox Header="Car Settings" IsEnabled="{Binding ControlsEnabled}" Margin="0,0,0,6">
                                    <StackPanel>
                                        <!-- Car Name -->
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock
                                        VerticalAlignment="Center" Text="{Binding CarNameDisplay}" FontWeight="SemiBold" Foreground="#D0D0F0"/>
                                        </DockPanel>

                                        <!-- Max Output -->
                                        <views:SliderRow Label="Power Scale" Min="1" Max="100"
                                                         IsInteger="True"
                                                     Value="{Binding MaxOutput, Mode=TwoWay}"
                                                     FillBrush="#DC3C3C"
                                                     Margin="0,3"/>
                                        <!-- Resting Point -->
                                        <views:SliderRow Label="Neutral Pt" Min="0" Max="30"
                                                         IsInteger="True"
                                                     Value="{Binding RestingPoint, Mode=TwoWay}"
                                                     FillBrush="#00BFFF"
                                                     Margin="0,3"/>

                                        <!-- Braking (Surge) -->
                                        <GroupBox Header="Braking (Surge)"
                                              Style="{StaticResource BlueBorderGroupStyle}"
                                              Margin="0,4">
                                            <StackPanel>
                                                <views:SliderRow Label="Curve"    Min="0.1" Max="5"
                                                                
                                                             ToolTip="{x:Static properties:Resources.Curve}"
                                                             Value="{Binding BrakingCurve, Mode=TwoWay}"
                                                             FillBrush="#6496FF" Margin="0,3"/>
                                                <views:SliderRow Label="Strength" Min="1"   Max="200"
                                                                 IsInteger="True"
                                                             Value="{Binding BrakingStrength, Mode=TwoWay}"
                                                             FillBrush="#6496FF" Margin="0,3"/>
                                                <CheckBox Content="Invert"
                                                      IsChecked="{Binding InvertSurge}"
                                                      Foreground="#6496FF"
                                                      Margin="0,4,0,2"
                                                      ToolTip="{x:Static properties:Resources.InvertSurgeToolTip}"/>
                                            </StackPanel>
                                        </GroupBox>

                                        <!-- Cornering (Sway) -->
                                        <GroupBox Header="Cornering (Sway)"
                                              Style="{StaticResource GreenBorderGroupStyle}"
                                              Margin="0,4">
                                            <StackPanel>
                                                <views:SliderRow Label="Curve"    Min="0.1" Max="10"
                                                             Value="{Binding CorneringCurve, Mode=TwoWay}"
                                                             FillBrush="#50C878" Margin="0,3"/>
                                                <views:SliderRow Label="Strength" Min="1"   Max="200"
                                                                 IsInteger="True"
                                                             Value="{Binding CorneringStrength, Mode=TwoWay}"
                                                             FillBrush="#50C878" Margin="0,3"/>
                                                <CheckBox Content="Invert"
                                                      IsChecked="{Binding InvertSway}"
                                                      Foreground="#50C878"
                                                      Margin="0,4,0,2"
                                                      ToolTip="{x:Static properties:Resources.InvertSwayToolTip}"/>
                                            </StackPanel>
                                        </GroupBox>

                                        <!-- Vertical (Heave) -->
                                        <GroupBox Header="Vertical (Heave)"
                                              Style="{StaticResource OrangeBorderGroupStyle}"
                                              Margin="0,4">
                                            <StackPanel>
                                                <views:SliderRow Label="Strength" Min="1" Max="200"
                                                                 IsInteger="True"
                                                             Value="{Binding VerticalStrength, Mode=TwoWay}"
                                                             FillBrush="#FF8040" Margin="0,3"/>
                                                <CheckBox Content="Invert"
                                                      IsChecked="{Binding InvertHeave}"
                                                      Foreground="#FF8040"
                                                      Margin="0,4,0,2"
                                                      ToolTip="{x:Static properties:Resources.InvertHeaveToolTip}"/>
                                            </StackPanel>
                                        </GroupBox>

                                        <!-- Gravity (Tilt) -->
                                        <GroupBox Header="Gravity (Tilt)" Margin="0,4">
                                            <StackPanel>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Pitch" Style="{StaticResource LabelStyle}"/>
                                                    <Slider Grid.Column="1" Minimum="1" Maximum="200"

                                                        Value="{Binding PitchStrength, Mode=TwoWay}"
                                                        Tag="#6496FF" Margin="4,0"
                                                        ToolTip="{x:Static properties:Resources.PitchStrengthToolTip}"/>
                                                    <CheckBox Grid.Column="2" Content="Invert"
                                                          IsChecked="{Binding InvertPitch}"
                                                          Margin="4,0,0,0"
                                                          ToolTip="{x:Static properties:Resources.InvertPitchToolTip}"/>
                                                </Grid>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Roll" Style="{StaticResource LabelStyle}"/>
                                                    <Slider Grid.Column="1" Minimum="1" Maximum="200"
                                                        Value="{Binding RollStrength, Mode=TwoWay}"
                                                        Tag="#50C878" Margin="4,0"
                                                        ToolTip="{x:Static properties:Resources.RollStrengthToolTip}"/>
                                                    <CheckBox Grid.Column="2" Content="Invert"
                                                          IsChecked="{Binding InvertRoll}"
                                                          Margin="4,0,0,0"
                                                          ToolTip="{x:Static properties:Resources.InvertRollToolTip}"/>
                                                </Grid>
                                            </StackPanel>
                                        </GroupBox>
                                    </StackPanel>
                                </GroupBox>

                                <!-- ?? Other (ABS + Negative Sway) ???????????????????????? -->
                                <Expander IsExpanded="{Binding EffectsExpanded, Mode=TwoWay}" IsEnabled="{Binding ControlsEnabled}" Margin="0,0,0,6" Foreground="#D0D0F0">
                                    <Expander.Header>
                                        <TextBlock Text="Effects" FontWeight="SemiBold" Foreground="#D0D0F0"/>
                                    </Expander.Header>
                                    <StackPanel Margin="0,6,0,0">
                                        <views:SliderRow Label="Neg. Sway" Min="0" Max="100"
                                                         IsInteger="True"
                                                     Value="{Binding NegativeSway, Mode=TwoWay}"
                                                     FillBrush="#50C878" Margin="0,3"/>

                                        <!-- ABS: enable + strength + test grouped together -->
                                        <GroupBox Header="ABS"
                                              Style="{StaticResource BlueBorderGroupStyle}"
                                              Margin="0,4">
                                            <StackPanel>
                                                <CheckBox Content="Enabled"
                                                      IsChecked="{Binding AbsEnabled}"
                                                      Foreground="#DC3C3C"
                                                      Margin="0,2,0,4"
                                                      ToolTip="{x:Static properties:Resources.AbsEnabledToolTip}"/>
                                                <views:SliderRow Label="Strength" Min="3" Max="30"
                                                                 IsInteger="True"
                                                             Value="{Binding AbsStrength, Mode=TwoWay}"
                                                             FillBrush="#DC3C3C" Margin="0,3"/>
                                                <Button Content="Test ABS"
                                                    Command="{Binding TestAbsCommand}"
                                                    HorizontalAlignment="Left"
                                                    Width="110" Margin="0,6,0,2"
                                                    Style="{DynamicResource BlueButton}"/>
                                            </StackPanel>
                                        </GroupBox>

                                        <!-- Kerbs Strip: enable + strength + test grouped together -->
                                        <GroupBox Header="Kerbs Strip"
                                              Style="{StaticResource GreenBorderGroupStyle}"
                                              Margin="0,4">
                                            <StackPanel>
                                                <CheckBox Content="Enabled"
                                                      IsChecked="{Binding RumbleStripEnabled, Mode=TwoWay}"
                                                      Foreground="CornflowerBlue"
                                                      Margin="0,2,0,4"
                                                      ToolTip="{x:Static properties:Resources.RumbleStripToolTip}"/>
                                                <views:SliderRow Label="Strength" Min="1" Max="30"
                                                                 IsInteger="True"
                                                             Value="{Binding RumbleStripStrength, Mode=TwoWay}"
                                                             FillBrush="CornflowerBlue" Margin="0,3"/>
                                                <Button Content="Test Rumble"
                                                    Command="{Binding TestRubbleCommand}"
                                                    HorizontalAlignment="Left"
                                                    Width="110" Margin="0,6,0,2"
                                                    Style="{DynamicResource BlueButton}"/>
                                            </StackPanel>
                                        </GroupBox>

                                        <!-- Gear Shift: enable + strength + time + test grouped together -->
                                        <GroupBox Header="Gear Shift"
                                              Style="{StaticResource OrangeBorderGroupStyle}"
                                              Margin="0,4">
                                            <StackPanel>
                                                <CheckBox Content="Enabled"
                                                      IsChecked="{Binding GearShiftEnabled, Mode=TwoWay}"
                                                      Foreground="CornflowerBlue"
                                                      Margin="0,2,0,4"
                                                      ToolTip="{x:Static properties:Resources.GearShiftToolTip}"/>
                                                <views:SliderRow Label="Strength" Min="0.1" Max="3"
                                                             Value="{Binding GearShiftStrength, Mode=TwoWay}"
                                                             FillBrush="CornflowerBlue" Margin="0,3"/>
                                                <views:SliderRow Label="Time (ms)" Min="100" Max="2000"
                                                                 IsInteger="True"
                                                             Value="{Binding GearShiftTime, Mode=TwoWay}"
                                                             FillBrush="CornflowerBlue" Margin="0,3"/>
                                                <Button Content="Test Gear Shift"
                                                    Command="{Binding TestGearShiftCommand}"
                                                    HorizontalAlignment="Left"
                                                    Width="120" Margin="0,6,0,2"
                                                    Style="{DynamicResource BlueButton}"/>
                                            </StackPanel>
                                        </GroupBox>
                                    </StackPanel>
                                </Expander>

                                <!-- Bottom padding -->
                                <Border Height="16"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Wind">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="#12121E"
                                  PanningMode="VerticalFirst" Margin="17,0,-8,0">
                            <StackPanel Margin="10,8" Width="332">
                                <TextBlock Text="Wind controls" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                                <StackPanel>
                                    <CheckBox Content="Enable for Car" IsChecked="{Binding EnableForCar, Mode=TwoWay}" Margin="0,0,6,6"
                                              ToolTip="{x:Static properties:Resources.WindEnableForCarToolTip}"/>
                                    <views:SliderRow Label="Resting Power" IsInteger="True" Min="0" Max="255" Value="{Binding WindRestingPower, Mode=TwoWay}" Margin="0,0,0,6"/>
                                    <views:SliderRow Label="Min Speed" IsInteger="True" Min="0" Max="255" Value="{Binding WindMinSpeed, Mode=TwoWay}" Margin="0,0,0,6" />
                                    <views:SliderRow Label="Min Power" IsInteger="True" Min="0" Max="255" Value="{Binding WindMinPower, Mode=TwoWay}" Margin="0,0,0,6" />
                                    <views:SliderRow Label="Power" IsInteger="True" Min="0" Max="255" Value="{Binding WindPowerPercentage, Mode=TwoWay}" Margin="0,0,0,6"/>
                                    <views:SliderRow Label="Curve" Min="0.1" Max="5" Value="{Binding WindCurve, Mode=TwoWay}" FillBrush="#50C878" Margin="0,0,0,6"/>
                                </StackPanel>

                                <!-- Wind graph -->
                                 <Border Margin="0,8,0,0" Background="#12121E" CornerRadius="4" Padding="6">
                                     <Image x:Name="img_WindGraph" Source="{Binding WindGraphImageSource}" Width="300" Height="140" Stretch="Fill" Loaded="WindImage_Loaded" />
                                 </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
