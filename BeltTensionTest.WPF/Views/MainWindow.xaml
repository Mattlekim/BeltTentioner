<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BeltTensionTest.WPF.ViewModels"
        xmlns:views="clr-namespace:BeltTensionTest.WPF.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:properties="clr-namespace:BeltTensionTest.WPF.Properties"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="BeltTensionTest.WPF.Views.MainWindow"
        Title="BBT"
        Width="420" MinWidth="420"
        MinHeight="400"
        Background="#12121E"
        Foreground="#A0A0BE"
        FontFamily="Segoe UI"
        ResizeMode="CanResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- MenuItem uses default template to preserve submenu behavior; custom styling removed -->
            <!-- Value converters inline -->
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <!-- Increase caption height slightly to ensure title bar controls are fully visible and clickable -->
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <DockPanel>

        <Border DockPanel.Dock="Top" Height="40" Background="{StaticResource BgLightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="BBT" MouseDown="TitleBar_MouseDown"/>
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Width="36" Height="24" Margin="2,0" Click="Minimize_Click" Content="─" ToolTip="Minimize" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            FontSize="14" FontWeight="SemiBold" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                    
                    <Button Width="36" Height="24" Margin="2,0" Click="Close_Click" Content="X" ToolTip="Close" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            FontSize="14" FontWeight="SemiBold" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- ?? Menu Bar ???????????????????????????????????????????????????? -->
        <Menu DockPanel.Dock="Top"
              Background="#12121E"
              Foreground="#A0A0BE">
            <MenuItem Header="Settings" Foreground="#A0A0BE" Click="MenuItem_Click">
                <MenuItem Header="Preferences..."
                          Foreground="#A0A0BE"
                          Click="OpenPreferences_Click"/>
                <Separator Background="#46466A"/>
                <MenuItem Header="Use iRacing Telemetry"
                          IsCheckable="True"
                          IsChecked="{Binding UseIracing}"
                          Foreground="#A0A0BE"/>
                <MenuItem Header="Use SimHub Telemetry"
                          IsCheckable="True"
                          IsChecked="{Binding UseSimHub}"
                          Foreground="#A0A0BE"/>
                <Separator Background="#46466A"/>
                <MenuItem Header="Open Testing Window..."
                          Foreground="#A0A0BE"
                          Click="OpenTestingWindow_Click"/>
                <MenuItem Header="Show Debug Log..."
                          Foreground="#A0A0BE"
                          Click="OpenDebugLog_Click"/>
                <MenuItem Header="Flash Nano..."
                          Foreground="#A0A0BE"
                          Click="OpenFlashNano_Click"/>
                <MenuItem Header="Motor Settings..."
                          Foreground="#A0A0BE"
                          Click="OpenMotorSettings_Click"/>
                <Separator Background="#46466A"/>
            </MenuItem>

            <!-- Help menu moved out from Settings -->
            <MenuItem Header="Help" Foreground="#A0A0BE">
                <MenuItem Header="Check for Updates..."
                          Foreground="#A0A0BE"
                          Command="{Binding CheckUpdatesCommand}"/>
                <MenuItem Header="About..."
                          Foreground="#A0A0BE"
                          Click="About_Click"/>
                <MenuItem Header="Buy me a coffee..."
                          Foreground="#A0A0BE"
                          Click="OpenBuyMeACoffee_Click"/>
            </MenuItem>
        </Menu>

        <!-- ?? Update Banner ??????????????????????????????????????????????? -->
        <Border DockPanel.Dock="Top"
                Background="#3A2A10"
                BorderBrush="#FFAA20"
                BorderThickness="0,0,0,1"
                Padding="10,5"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Download"
                        Background="#FFAA20"
                        Foreground="#12121E"
                        Padding="10,3"
                        Command="{Binding OpenUpdateCommand}"
                        Margin="6,0,0,0"/>
                <TextBlock VerticalAlignment="Center"
                           Foreground="#FFCC60"><Run Text="Update available: "/><Run Text=" "/><Run Text="{Binding UpdateTag, Mode=OneWay}"
                         FontWeight="Bold"/></TextBlock>
            </DockPanel>
        </Border>

        <!-- Main content: keep the connect controls visible, move everything else into tabs -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0">

            <!-- Device Connection (keep visible outside tabs) -->
            <Border Background="#1C1C2E" CornerRadius="6" Padding="10,10" Margin="10,8" Width="332">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Device on/off + label -->
                    <views:StatusIndicatorView Grid.Row="0"
                                               Label="{Binding DeviceStatusText}"
                                               IsOn="{Binding DeviceIsOn}"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>

                    <!-- Connect + AutoConnect row -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  Content="Connect On Startup"
                                  IsChecked="{Binding AutoConnect}"
                                  VerticalAlignment="Center"
                                  ToolTip="Automatically connect to the device on application startup."/>
                        <Button
                                x:Name="bnt_Connect"
                                Content="Connect"
                                Command="{Binding ConnectCommand}"
                                Background="Green"
                                Foreground="Black"
                                
                                IsEnabled="True" Click="bnt_Connect_Click" Grid.ColumnSpan="2" Margin="222,0,0,0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Top indicators (iRacing / SimHub) moved out of tabs -->
            <Border Margin="10,4,10,6" Background="#1C1C2E" CornerRadius="6" Padding="10,8" Width="332">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <views:StatusIndicatorView Grid.Column="0" Label="IRacing:" IsOn="{Binding IracingIsOn}"/>
                    <views:StatusIndicatorView
            Margin="8,0,0,0" Label="SimHub:" IsOn="{Binding SimHubIsOn}" Grid.Column="1"/>
                </Grid>
            </Border>
            <!-- ?? SimHub group ????????????????????????????????????????? -->
            <GroupBox Header="SimHub"
                                      IsEnabled="{Binding SimHubGroupEnabled}"
                                      Visibility="{Binding SimHubIsOn, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding SimHubText}"
                                               Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding MenuStateText}"
                                               Style="{StaticResource LabelStyle}"
                                               HorizontalAlignment="Right"/>
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2"
                                                Orientation="Horizontal" Margin="0,4,0,0">
                        <views:StatusIndicatorView Label="Vertical"   IsOn="{Binding SupportVertical}"  Margin="0,0,8,0"/>
                        <views:StatusIndicatorView Label="Braking"    IsOn="{Binding SupportBrake}"     Margin="0,0,8,0"/>
                        <views:StatusIndicatorView Label="Cornering"  IsOn="{Binding SupportCornering}"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Border Margin="10,0,10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Background="{StaticResource BgBrush}">
                <TabControl Style="{StaticResource MyTabControl}" Width="370" BorderThickness="0" Background="{StaticResource BgBrush}">

                    <TabItem Header="Belt Tentioner">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="#12121E"
                                  PanningMode="VerticalFirst" Margin="2,0,1,0">
                            <StackPanel Margin="10,8" Width="332">

                                <!-- iRacing/SimHub indicators moved to top of window -->

                                <!-- ?? Car Settings ??????????????????????????????????????? -->
                                <GroupBox Header="Car Settings" IsEnabled="{Binding ControlsEnabled}" Margin="0,0,0,6">
                                    <StackPanel>
                                        <!-- Car Name -->
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock
                                        VerticalAlignment="Center" Text="{Binding CarNameDisplay}" FontWeight="SemiBold" Foreground="#D0D0F0"/>
                                        </DockPanel>

                                        <!-- Max Output -->
                                        <views:SliderRow Label="Max Output" Min="1" Max="100"
                                                         IsInteger="True"
                                                     Value="{Binding MaxOutput, Mode=TwoWay}"
                                                     FillBrush="#DC3C3C"
                                                     Margin="0,3"/>
                                        <!-- Resting Point -->
                                        <views:SliderRow Label="Resting Pt" Min="0" Max="30"
                                                         IsInteger="True"
                                                     Value="{Binding RestingPoint, Mode=TwoWay}"
                                                     FillBrush="#00BFFF"
                                                     Margin="0,3"/>

                                        <!-- Braking (Surge) -->
                                        <GroupBox Header="Braking (Surge)"
                                              Style="{StaticResource BlueBorderGroupStyle}"
                                              Margin="0,4">
                                            <StackPanel>
                                                <views:SliderRow Label="Curve"    Min="0.1" Max="5"
                                                                
                                                             ToolTip="{x:Static properties:Resources.Curve}"
                                                             Value="{Binding BrakingCurve, Mode=TwoWay}"
                                                             FillBrush="#6496FF" Margin="0,3"/>
                                                <views:SliderRow Label="Strength" Min="1"   Max="200"
                                                                 IsInteger="True"
                                                             Value="{Binding BrakingStrength, Mode=TwoWay}"
                                                             FillBrush="#6496FF" Margin="0,3"/>
                                                <CheckBox Content="Invert"
                                                      IsChecked="{Binding InvertSurge}"
                                                      Foreground="#6496FF"
                                                      Margin="0,4,0,2"
                                                      ToolTip="Invert braking (surge) direction."/>
                                            </StackPanel>
                                        </GroupBox>

                                        <!-- Cornering (Sway) -->
                                        <GroupBox Header="Cornering (Sway)"
                                              Style="{StaticResource GreenBorderGroupStyle}"
                                              Margin="0,4">
                                            <StackPanel>
                                                <views:SliderRow Label="Curve"    Min="0.1" Max="10"
                                                             Value="{Binding CorneringCurve, Mode=TwoWay}"
                                                             FillBrush="#50C878" Margin="0,3"/>
                                                <views:SliderRow Label="Strength" Min="1"   Max="200"
                                                                 IsInteger="True"
                                                             Value="{Binding CorneringStrength, Mode=TwoWay}"
                                                             FillBrush="#50C878" Margin="0,3"/>
                                                <CheckBox Content="Invert"
                                                      IsChecked="{Binding InvertSway}"
                                                      Foreground="#50C878"
                                                      Margin="0,4,0,2"
                                                      ToolTip="Invert cornering (sway) direction."/>
                                            </StackPanel>
                                        </GroupBox>

                                        <!-- Vertical (Heave) -->
                                        <GroupBox Header="Vertical (Heave)"
                                              Style="{StaticResource OrangeBorderGroupStyle}"
                                              Margin="0,4">
                                            <StackPanel>
                                                <views:SliderRow Label="Strength" Min="1" Max="200"
                                                                 IsInteger="True"
                                                             Value="{Binding VerticalStrength, Mode=TwoWay}"
                                                             FillBrush="#FF8040" Margin="0,3"/>
                                                <CheckBox Content="Invert"
                                                      IsChecked="{Binding InvertHeave}"
                                                      Foreground="#FF8040"
                                                      Margin="0,4,0,2"
                                                      ToolTip="Invert vertical (heave) direction."/>
                                            </StackPanel>
                                        </GroupBox>

                                        <!-- Gravity (Tilt) -->
                                        <GroupBox Header="Gravity (Tilt)" Margin="0,4">
                                            <StackPanel>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Pitch" Style="{StaticResource LabelStyle}"/>
                                                    <Slider Grid.Column="1" Minimum="1" Maximum="200"

                                                        Value="{Binding PitchStrength, Mode=TwoWay}"
                                                        Tag="#6496FF" Margin="4,0"
                                                        ToolTip="Adjust pitch strength applied by gravity (tilt)."/>
                                                    <CheckBox Grid.Column="2" Content="Invert"
                                                          IsChecked="{Binding InvertPitch}"
                                                          Margin="4,0,0,0"
                                                          ToolTip="Invert pitch tilt effect."/>
                                                </Grid>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Roll" Style="{StaticResource LabelStyle}"/>
                                                    <Slider Grid.Column="1" Minimum="1" Maximum="200"
                                                        Value="{Binding RollStrength, Mode=TwoWay}"
                                                        Tag="#50C878" Margin="4,0"
                                                        ToolTip="Adjust roll strength applied by gravity (tilt)."/>
                                                    <CheckBox Grid.Column="2" Content="Invert"
                                                          IsChecked="{Binding InvertRoll}"
                                                          Margin="4,0,0,0"
                                                          ToolTip="Invert roll tilt effect."/>
                                                </Grid>
                                            </StackPanel>
                                        </GroupBox>
                                    </StackPanel>
                                </GroupBox>

                                <!-- ?? Other (ABS + Negative Sway) ???????????????????????? -->
                                <GroupBox Header="Other" IsEnabled="{Binding ControlsEnabled}" Margin="0,0,0,6">
                                    <StackPanel>
                                        <views:SliderRow Label="Neg. Sway" Min="0" Max="100"
                                                         IsInteger="True"
                                                     Value="{Binding NegativeSway, Mode=TwoWay}"
                                                     FillBrush="#50C878" Margin="0,3"/>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="ABS Effect" Style="{StaticResource LabelStyle}"/>
                                            <CheckBox  Grid.Column="2" Content="Enabled"
                                                   IsChecked="{Binding AbsEnabled}"
                                                   Margin="8,0,0,0"
                                                   ToolTip="Enable ABS behavior which reduces output during braking events."/>
                                        </Grid>
                                        <views:SliderRow Label="ABS Str." Min="3" Max="30"
                                                         IsInteger="True"
                                                     Value="{Binding AbsStrength, Mode=TwoWay}"
                                                     FillBrush="#DC3C3C" Margin="0,3"/>
                                        <!-- Rubble / Rumble strip controls -->
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Rubble Strip" Style="{StaticResource LabelStyle}"/>
                                            <CheckBox Grid.Column="2" Content="Enabled"
                                                      IsChecked="{Binding RubbleStripEnabled}"
                                                      Margin="8,0,0,0"
                                                      ToolTip="Enable rubble strip behavior."/>
                                        </Grid>
                                        <views:SliderRow Label="Rubble Str." Min="1" Max="200"
                                                         IsInteger="True"
                                                     Value="{Binding RubbleStripStrength, Mode=TwoWay}"
                                                     FillBrush="CornflowerBlue" Margin="0,3"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Content="Test ABS"
                                                Command="{Binding TestAbsCommand}"
                                                HorizontalAlignment="Left"
                                                Width="80" Margin="4,6,4,2"
                                                Style="{DynamicResource RedButton}"/>
                                            <Button Content="Test Rubble"
                                                Command="{Binding TestRubbleCommand}"
                                                HorizontalAlignment="Left"
                                                Width="90" Margin="4,6,4,2" Style="{DynamicResource BlueButton}"/>      
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Bottom padding -->
                                <Border Height="16"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Wind">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Background="#12121E"
                                  PanningMode="VerticalFirst" Margin="17,0,-8,0">
                            <StackPanel Margin="10,8" Width="332">
                                <TextBlock Text="Wind controls" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>
                                <StackPanel>
                                    <CheckBox Content="Enable for Car" IsChecked="{Binding EnableForCar, Mode=TwoWay}" Margin="0,0,6,6"
                                              ToolTip="Enable wind effects for this car."/>
                                    <views:SliderRow Label="Resting Power" IsInteger="True" Min="0" Max="255" Value="{Binding WindRestingPower, Mode=TwoWay}" Margin="0,0,0,6"/>
                                    <views:SliderRow Label="Min Speed" IsInteger="True" Min="0" Max="255" Value="{Binding WindMinSpeed, Mode=TwoWay}" Margin="0,0,0,6" />
                                    <views:SliderRow Label="Min Power" IsInteger="True" Min="0" Max="255" Value="{Binding WindMinPower, Mode=TwoWay}" Margin="0,0,0,6" />
                                    <views:SliderRow Label="Power" IsInteger="True" Min="0" Max="255" Value="{Binding WindPowerPercentage, Mode=TwoWay}" Margin="0,0,0,6"/>
                                    <views:SliderRow Label="Curve" Min="0.1" Max="5" Value="{Binding WindCurve, Mode=TwoWay}" FillBrush="#50C878" Margin="0,0,0,6"/>
                                </StackPanel>

                                <!-- Wind graph -->
                                <Border Margin="0,8,0,0" Background="#12121E" CornerRadius="4" Padding="6">
                                    <Image Source="{Binding WindGraphImageSource}" Width="300" Height="140" Stretch="Fill" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
