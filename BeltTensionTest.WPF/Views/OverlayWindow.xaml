<Window x:Class="BeltTensionTest.WPF.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenXR Overlay" Width="560" Height="360"
        Background="Transparent" Foreground="#A0A0BE"
        FontFamily="Segoe UI" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="#12121E" CornerRadius="6" BorderBrush="#FF333344" BorderThickness="1" Padding="0">
        <DockPanel>
            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="36" Background="{StaticResource BgLightBrush}">
                <Grid MouseDown="TitleBar_MouseDown">
                    <TextBlock VerticalAlignment="Center" Margin="12,0,40,0" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Text="OpenXR Overlay" />
                    <Button Width="36" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                            Click="CloseButton_Click" Background="Transparent" BorderBrush="Transparent" Padding="0"
                            BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="16" Height="16">
                                <Path Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                      Data="M4,4 L12,12 M12,4 L4,12" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <!-- Log status only -->
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" x:Name="StatusLabel" Margin="0,0,0,8"
                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                           Text="Initialising…"/>

                <TextBox Grid.Row="1" x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
                         Background="#0E0E1A" Foreground="#A0A0BE" BorderBrush="#46466A" BorderThickness="1"/>
            </Grid>
        </DockPanel>
    </Border>
</Window>
