<Window x:Class="BeltTensionTest.WPF.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenXR Overlay" Width="620" Height="470"
        Background="Transparent" Foreground="#A0A0BE"
        FontFamily="Segoe UI" WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="#12121E" CornerRadius="6" BorderBrush="#FF333344" BorderThickness="1" Padding="0">
        <DockPanel>
            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Height="36" Background="{StaticResource BgLightBrush}">
                <Grid MouseDown="TitleBar_MouseDown">
                    <TextBlock VerticalAlignment="Center" Margin="12,0,40,0" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Text="OpenXR Overlay — MonoXR example" />
                    <Button Width="36" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                            Click="CloseButton_Click" Background="Transparent" BorderBrush="Transparent" Padding="0"
                            BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="16" Height="16">
                                <Path Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2"
                                      Data="M4,4 L12,12 M12,4 L4,12" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </Grid>
            </Border>

            <Grid Margin="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Live preview of the pixels sent to the overlay -->
                <Border Grid.Column="0" Width="256" Height="256" CornerRadius="4"
                        BorderBrush="#46466A" BorderThickness="1" Background="#0E0E1A" VerticalAlignment="Top">
                    <Image x:Name="PreviewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                </Border>

                <!-- Controls / status -->
                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#A0A0BE"
                               Text="Draws an animated square and publishes it as an OpenXR quad overlay through MonoXR. Start any D3D11 OpenXR app to see it in VR."/>

                    <TextBlock Text="Layer status" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="StatusLabel" Margin="0,2,0,10" Text="Initialising…"/>

                    <TextBlock Text="Reference space" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,10">
                        <RadioButton x:Name="WorldRadio" Content="World-locked" IsChecked="True"
                                     Foreground="#A0A0BE" Margin="0,0,14,0" Checked="Space_Changed"/>
                        <RadioButton x:Name="HeadRadio" Content="Head-locked"
                                     Foreground="#A0A0BE" Checked="Space_Changed"/>
                    </StackPanel>

                    <CheckBox x:Name="SpinCheck" Content="Spin the overlay" IsChecked="True"
                              Foreground="#A0A0BE" Margin="0,0,0,14"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="StartButton" Content="Start" Width="80" Margin="0,0,8,0"
                                Click="Start_Click" Style="{DynamicResource BlueButton}"/>
                        <Button x:Name="StopButton" Content="Stop" Width="80"
                                Click="Stop_Click" Style="{DynamicResource BlueButton}"/>
                    </StackPanel>

                    <TextBlock x:Name="FrameLabel" Margin="0,12,0,0" Foreground="#6C6C8A" Text="Frames: 0"/>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>
