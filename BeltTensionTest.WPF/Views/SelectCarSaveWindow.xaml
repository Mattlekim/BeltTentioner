<Window x:Class="BeltTensionTest.WPF.Views.SelectCarSaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Save to Load" Height="300" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select an existing save to load for this car:" FontWeight="Bold" Margin="0,0,0,8"/>

        <ListBox x:Name="ListBoxSaves" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Width="88" Margin="0,0,8,0" Click="Ok_Click" IsDefault="True">OK</Button>
            <Button Width="88" Click="Cancel_Click" IsCancel="True">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>