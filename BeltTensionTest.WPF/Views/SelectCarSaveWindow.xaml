<Window x:Class="BeltTensionTest.WPF.Views.SelectCarSaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Save to Load" Height="300" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}" WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False">

    <Border Background="{StaticResource BgBrush}" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource BgLightBrush}" MouseDown="TitleBar_MouseDown">
                <!-- Ensure title is visible: explicitly set alignment, z-index and a hard-coded bright foreground as fallback -->
                <TextBlock Text="Select Profie"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="12,0,48,0"
                           FontWeight="SemiBold"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           Foreground="#D0D0F0"
                           Panel.ZIndex="1"
                           Visibility="Visible" />
                <Button Width="36" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Click="CloseButton_Click"
                        Background="Transparent" BorderBrush="Transparent" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                    <Viewbox Width="14" Height="14">
                        <Canvas Width="16" Height="16">
                            <Path Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="2" Data="M4,4 L12,12 M12,4 L4,12" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Select an existing save to load for this car:" FontWeight="Bold" Margin="0,0,0,8" Foreground="{StaticResource TextPrimaryBrush}"/>

                <ListBox x:Name="ListBoxSaves" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Width="88" Margin="0,0,8,0" Click="Ok_Click" IsDefault="True" Style="{DynamicResource GreenButton}">OK</Button>
                    <Button Width="88" Click="Cancel_Click" IsCancel="True" Style="{DynamicResource BlueButton}">Cancel</Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
