<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="BeltTensionTest.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:BeltTensionTest.WPF.Views"
        xmlns:properties="clr-namespace:BeltTensionTest.WPF.Properties"
        Title="Preferences" Height="460" Width="461" WindowStartupLocation="CenterOwner"
        Background="#12121E" Foreground="#A0A0BE" FontFamily="Segoe UI" WindowStyle="None">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6"/>
    </shell:WindowChrome.WindowChrome>

    <DockPanel>
        <Border DockPanel.Dock="Top" Height="40" Background="{StaticResource BgLightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Text="Preferences" MouseDown="TitleBar_MouseDown"/>
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Width="36" Height="24" Margin="2,0" Click="Close_Click" Content="X" ToolTip="{x:Static properties:Resources.CloseToolTip}" Background="Transparent" Foreground="{StaticResource TextPrimaryBrush}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            FontSize="14" FontWeight="SemiBold" Padding="0" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btn_Ok" Content="OK" Width="80" Margin="0,0,8,0" Click="Ok_Click" Style="{DynamicResource GreenButton}"/>
            <Button x:Name="btn_Cancel" Content="Cancel" Width="80" Click="Cancel_Click" Style="{DynamicResource BlueButton}"/>
        </StackPanel>
        <TabControl Style="{StaticResource MyTabControl}" Background="Transparent" BorderBrush="Transparent">
                <TabItem Header="General">
                    <StackPanel Margin="6" Orientation="Vertical">
                        <CheckBox x:Name="chk_AutoConnect" Content="Connect On Startup" Foreground="#A0A0BE" Margin="0,4"
                                  ToolTip="{x:Static properties:Resources.AutoConnectToolTip}"/>
                        <CheckBox x:Name="chk_StartWithWindows" Content="Start with Windows" Foreground="#A0A0BE" Margin="0,4"
                                  ToolTip="{x:Static properties:Resources.StartWithWindowsToolTip}"/>
                        <CheckBox x:Name="chk_MinimizeToTaskbar" Content="Minimize to taskbar when closed" Foreground="#A0A0BE" Margin="0,4"
                                  ToolTip="{x:Static properties:Resources.MinimizeToTaskbarToolTip}"/>

                        <Separator Margin="0,8" Background="#46466A"/>

                        <TextBlock Text="Telemetry" FontWeight="SemiBold" Margin="0,4,0,4" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <RadioButton x:Name="rb_Iracing" GroupName="TelemetrySource" Content="Use iRacing Telemetry"
                                     Foreground="#A0A0BE" Margin="0,4" Checked="Telemetry_Checked"/>
                        <RadioButton x:Name="rb_SimHub" GroupName="TelemetrySource" Content="Use SimHub Telemetry"
                                     Foreground="#A0A0BE" Margin="0,4" Checked="Telemetry_Checked"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="KeyBindings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Toggle fan:" VerticalAlignment="Center" Margin="0,6" Foreground="#A0A0BE" />
                        <views:KeyBindingControl x:Name="kb_ToggleFan" Grid.Row="0" Grid.Column="1" Margin="6,4" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Increase resting power:" VerticalAlignment="Center" Margin="0,6" Foreground="#A0A0BE" />
                        <views:KeyBindingControl x:Name="kb_IncreaseWindRest" Grid.Row="1" Grid.Column="1" Margin="6,4" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Decrease resting power:" VerticalAlignment="Center" Margin="0,6" Foreground="#A0A0BE" />
                        <views:KeyBindingControl x:Name="kb_DecreaseWindRest" Grid.Row="2" Grid.Column="1" Margin="6,4" />

                        <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8" Background="#46466A"/>

                        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="VR Overlay" FontWeight="SemiBold" Margin="0,4,0,4" Foreground="{StaticResource TextPrimaryBrush}" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Navigate up:" VerticalAlignment="Center" Margin="0,6" Foreground="#A0A0BE" />
                        <views:KeyBindingControl x:Name="kb_NavUp" Grid.Row="5" Grid.Column="1" Margin="6,4" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Navigate down:" VerticalAlignment="Center" Margin="0,6" Foreground="#A0A0BE" />
                        <views:KeyBindingControl x:Name="kb_NavDown" Grid.Row="6" Grid.Column="1" Margin="6,4" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Increase:" VerticalAlignment="Center" Margin="0,6" Foreground="#A0A0BE" />
                        <views:KeyBindingControl x:Name="kb_NavIncrease" Grid.Row="7" Grid.Column="1" Margin="6,4" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Decrease:" VerticalAlignment="Center" Margin="0,6" Foreground="#A0A0BE" />
                        <views:KeyBindingControl x:Name="kb_NavDecrease" Grid.Row="8" Grid.Column="1" Margin="6,4" />

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Next control:" VerticalAlignment="Center" Margin="0,6" Foreground="#A0A0BE" />
                        <views:KeyBindingControl x:Name="kb_NavNextControl" Grid.Row="9" Grid.Column="1" Margin="6,4" />

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Previous control:" VerticalAlignment="Center" Margin="0,6" Foreground="#A0A0BE" />
                        <views:KeyBindingControl x:Name="kb_NavPrevControl" Grid.Row="10" Grid.Column="1" Margin="6,4" />

                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="OpenXR">
                    <StackPanel Margin="6" Orientation="Vertical">
                        <TextBlock Text="Overlays" FontWeight="SemiBold" Margin="0,4,0,4" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Separator Margin="0,0,0,8" Background="#46466A"/>

                        <CheckBox x:Name="chk_YouTubeOverlay" Content="YouTube overlay" Foreground="#A0A0BE" Margin="0,4"
                                  ToolTip="Adds the YouTube live-chat panel to the OpenXR overlay. Takes effect the next time the overlay window is opened."/>

                        <Separator Margin="0,8" Background="#46466A"/>

                        <CheckBox x:Name="chk_AutoStartOverlay" Content="Start OpenXR overlay automatically" Foreground="#A0A0BE" Margin="0,4"
                                  ToolTip="Opens the OpenXR overlay window automatically when the app starts."/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </DockPanel>
    </DockPanel>
</Window>
