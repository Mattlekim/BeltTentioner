<Window x:Class="BeltTensionTest.WPF.Shared.ThemedMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ThemedMessageWindow" Height="200" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        Foreground="White"
        ShowInTaskbar="False">

    <Border Background="#FF222222" CornerRadius="6" BorderBrush="#FF444444" BorderThickness="1" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#FF2A2A2A" MouseDown="TitleBar_MouseDown">
                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Title}" VerticalAlignment="Center" Margin="12,0,40,0" FontWeight="SemiBold" />
                <Button x:Name="PART_CloseButton" Width="36" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Click="CloseButton_Click"
                        Background="Transparent" BorderBrush="Transparent" Foreground="White" FontSize="12" Content="?" />
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="12,12,12,0">
                <TextBlock x:Name="TextMessage" TextWrapping="Wrap" FontSize="14" Foreground="White" />
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,12,12" x:Name="ButtonsPanel" />
        </Grid>
    </Border>
</Window>
